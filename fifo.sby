[tasks]
basic bmc
repro_bug1 prove
repro_bug2 prove
repro_bug3 prove
cover
noverific cover
basic cover : default

[options]
cover:
mode cover
--
prove:
mode prove
--
bmc: 
mode bmc
depth 32
--

[engines]
smtbmc boolector

[script]
repro_bug1: read -define BUG1=1
repro_bug2: read -define BUG2=1
repro_bug3: read -define BUG3=1
noverific: read -noverific
read -formal fifo.sv
prep -top fifo

[files]
fifo.sv
